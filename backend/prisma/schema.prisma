// Fase 1: Base del sistema (usuarios, roles, áreas/tags, notificaciones)
// Los módulos de fases siguientes (Anuncios, Documentos, Vacaciones, Chat,
// Programaciones, Alumnos, Solicitudes) se irán agregando a este mismo
// archivo en cada fase, sin tocar lo ya construido.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN       // acceso total, gestiona usuarios, áreas, jerarquía
  GERENCIA
  RRHH
  MARKETING
  VENTAS
  INSTRUCTOR
  EMPLEADO
}

enum WorkStatus {
  PRESENCIAL
  HOME_OFFICE
  VACACIONES
}

model Area {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  color     String     @default("#1c2b4a") // color del tag, en formato hexadecimal
  createdAt DateTime   @default(now())
  users     UserArea[]
  documentPermissions DocumentTypeAreaPermission[]
  chat Conversation?
}

model UserArea {
  userId Int
  areaId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  area   Area @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([userId, areaId])
}

model User {
  id                  Int        @id @default(autoincrement())
  sequenceNumber      Int        @unique // usado para generar el username (0001, 0002...)
  username            String     @unique // ej: J.Rios.Espac.0001
  firstName           String
  lastName             String
  email               String     @unique // correo institucional
  passwordHash        String
  mustChangePassword  Boolean    @default(true)
  role                Role       @default(EMPLEADO)
  cargo               String?    // puesto (ej: "Asesora de Ventas")
  signatureData       String?    @db.Text // firma digital guardada (imagen en base64)
profilePhoto        String?    @db.Text // foto de perfil (imagen en base64)
  schedule            Json       @default("[]") // horario semanal: [{ day, active, start, end }]
  scheduleNote        String?    // nota adicional opcional (ej: "Turno rotativo cada 2 semanas")
  workStatus          WorkStatus @default(PRESENCIAL)
  hierarchyOrder       Int        @default(0)   // orden dentro de su nivel, editable por admin
  managerId           Int?       // jefe directo, para el organigrama
  manager             User?      @relation("Jerarquia", fields: [managerId], references: [id])
  reports             User[]     @relation("Jerarquia")
  vacationDaysTotal   Int        @default(30)
  vacationDaysUsed    Int        @default(0)
  isActive            Boolean    @default(true)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  areas         UserArea[]
  notifications Notification[]
  announcements Announcement[]
  events        CalendarEvent[]
  announcementLikes    AnnouncementLike[]
  announcementComments AnnouncementComment[]
  documentosPersonales Document[] @relation("DocumentosPersonales")
  documentosSubidos    Document[] @relation("DocumentosSubidos")
  plantillasCreadas    DocumentTemplate[]
  borradoresDueno      DocumentDraft[] @relation("BorradorDueno")
  borradoresCreados    DocumentDraft[] @relation("BorradorCreador")
  firmasPendientes     DocumentSigner[]
  vacacionesPropias    VacationRequest[] @relation("VacacionesPropias")
  vacacionesDecididas  VacationRequest[] @relation("VacacionesDecididas")
  chatParticipaciones  ConversationParticipant[]
  mensajesEnviados     ChatMessage[]
  sesionesComoInstructor ScheduleSession[] @relation("SesionesComoInstructor")
  sesionesCreadas        ScheduleSession[] @relation("SesionesCreadas")
  solicitudesCreadas     Request[] @relation("SolicitudesCreadas")
  solicitudesRecibidas   Request[] @relation("SolicitudesRecibidas")
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  imageData String?  @db.Text // imagen del anuncio, guardada como base64
  pinned    Boolean  @default(false)
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  likes    AnnouncementLike[]
  comments AnnouncementComment[]
}

model AnnouncementLike {
  id             Int          @id @default(autoincrement())
  announcementId Int
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         Int
  user           User         @relation(fields: [userId], references: [id])
  createdAt      DateTime     @default(now())

  @@unique([announcementId, userId])
}

model AnnouncementComment {
  id             Int          @id @default(autoincrement())
  announcementId Int
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  authorId       Int
  author         User         @relation(fields: [authorId], references: [id])
  content        String
  createdAt      DateTime     @default(now())
}

model CalendarEvent {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  date        DateTime // solo se usa la fecha (día); la hora se ignora
  color       String   @default("#1c2b4a")
  createdById Int
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "SISTEMA", "SOLICITUD", "PROGRAMACION", "ANUNCIO", "VACACIONES", "CHAT"...
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum DocumentScope {
  GENERAL  // documento oficial, visible para toda la empresa (o solo ciertas áreas)
  PERSONAL // documento privado de un solo usuario (ej: acta de préstamo, contrato)
}

model DocumentType {
  id          Int      @id @default(autoincrement())
  name        String   @unique // ej: "Contratos", "Actas de préstamo", "Manuales", "Políticas"
  createdAt   DateTime @default(now())
  documents   Document[]
  permissions DocumentTypeAreaPermission[] // si no tiene ninguna, es visible para todas las áreas
  drafts      DocumentDraft[]
}

model DocumentTypeAreaPermission {
  id             Int          @id @default(autoincrement())
  documentTypeId Int
  documentType   DocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
  areaId         Int
  area           Area         @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@unique([documentTypeId, areaId])
}

model Document {
  id             Int           @id @default(autoincrement())
  title          String
  fileName       String
  mimeType       String
  fileData       String        @db.Text // el archivo, guardado como base64
  scope          DocumentScope
  documentTypeId Int?
  documentType   DocumentType? @relation(fields: [documentTypeId], references: [id])
  ownerId        Int?          // solo para documentos PERSONAL: de quién es
  owner          User?         @relation("DocumentosPersonales", fields: [ownerId], references: [id])
  uploadedById   Int
  uploadedBy     User          @relation("DocumentosSubidos", fields: [uploadedById], references: [id])
  createdAt      DateTime      @default(now())

  draft DocumentDraft?
}

model DocumentTemplate {
  id          Int      @id @default(autoincrement())
  name        String   // ej: "Acta de préstamo de equipo", "Constancia de trabajo"
  intro       String   @db.Text // texto libre; admite {{persona}}, {{cargo}}, {{fecha}}, {{firmante2}}, {{firmante2Cargo}}
  fields      Json     @default("[]") // campos personalizados: [{ key, label, placeholder }]
  createdById Int
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  drafts DocumentDraft[]
}

// Un documento "en camino": se creó desde una plantilla con sus datos llenados,
// pero todavía falta que una o dos personas pongan su firma antes de quedar
// como un Document final y definitivo.
model DocumentDraft {
  id             Int          @id @default(autoincrement())
  templateId     Int
  template       DocumentTemplate @relation(fields: [templateId], references: [id])
  title          String
  values         Json         @default("{}") // valores llenados de los campos personalizados
  fecha          DateTime
  imageData      String?      @db.Text // imagen opcional adjunta al documento
  documentTypeId Int?
  documentType   DocumentType? @relation(fields: [documentTypeId], references: [id])
  ownerId        Int          // persona principal (dueña final del documento)
  owner          User         @relation("BorradorDueno", fields: [ownerId], references: [id])
  createdById    Int
  createdBy      User         @relation("BorradorCreador", fields: [createdById], references: [id])
  status         String       @default("PENDIENTE") // PENDIENTE | COMPLETADO
  documentId     Int?         @unique // una vez firmado por todos, apunta al Document final
  document       Document?    @relation(fields: [documentId], references: [id])
  createdAt      DateTime     @default(now())

  signers DocumentSigner[]
}

// Cada persona que debe firmar un borrador (1 o 2 por documento)
model DocumentSigner {
  id        Int       @id @default(autoincrement())
  draftId   Int
  draft     DocumentDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  order     Int       // 1 = firmante principal, 2 = segundo firmante
  signedAt  DateTime?
  signature String?   @db.Text // la firma que se usó en esta ocasión

  @@unique([draftId, userId])
}

// Solicitud de vacaciones. Solo Admin, Gerencia y RRHH pueden ver y aprobar/rechazar.
model VacationRequest {
  id           Int       @id @default(autoincrement())
  userId       Int
  user         User      @relation("VacacionesPropias", fields: [userId], references: [id])
  startDate    DateTime
  endDate      DateTime
  days         Int       // cantidad de días solicitados (calculado)
  reason       String?   // motivo, no obligatorio
  status       String    @default("PENDIENTE") // PENDIENTE | APROBADA | RECHAZADA
  decidedById  Int?
  decidedBy    User?     @relation("VacacionesDecididas", fields: [decidedById], references: [id])
  decisionNote String?
  createdAt    DateTime  @default(now())
  decidedAt    DateTime?
}

enum ConversationType {
  DIRECT // chat privado entre 2 personas
  AREA   // chat grupal de un área/tag (todos los que tengan ese tag)
}

model Conversation {
  id        Int              @id @default(autoincrement())
  type      ConversationType
  areaId    Int?             @unique // solo para tipo AREA (un solo chat por área)
  area      Area?            @relation(fields: [areaId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  participants ConversationParticipant[]
  messages     ChatMessage[]
}

// Quiénes pertenecen a cada conversación. En chats DIRECT son las 2 personas;
// en chats de AREA se sincroniza solo con quien tenga ese tag asignado.
model ConversationParticipant {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         Int
  user           User         @relation(fields: [userId], references: [id])
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?    // hasta qué momento ya vio los mensajes de este chat

  @@unique([conversationId, userId])
}

model ChatMessage {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       Int
  sender         User         @relation(fields: [senderId], references: [id])
  content        String?      @db.Text // texto del mensaje (los emojis van incluidos aquí mismo)
  fileData       String?      @db.Text // archivo adjunto, en base64
  fileName       String?
  mimeType       String?
  createdAt      DateTime     @default(now())
}

// Cursos que ofrece ESPAC (ej: "Piloto Privado", "Piloto Comercial"). Solo Admin los crea.
model Course {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  students  Student[]
}

model Student {
  id                Int      @id @default(autoincrement())
  sequenceNumber    Int      @unique // usado para generar el código (00001, 00002...)
  code              String   @unique // ej: ESPAC-00001
  firstName         String
  lastName          String
  email             String?
  phone             String?
  courseId          Int?
  course            Course?  @relation(fields: [courseId], references: [id])
  enrollmentDate    DateTime @default(now()) // fecha de ingreso/matrícula (editable, distinta de createdAt)
  groundCourseHours Float    @default(0) // horas de curso en tierra
  flightHours       Float    @default(0) // horas de vuelo
  simulatorHours    Float    @default(0) // horas de simulador
  notes             String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  sessions ScheduleSession[]
}

// Una sesión programada: clase de teoría, simulador, o vuelo. La agenda el
// capitán del área (o Admin/Gerencia), y se notifica al instructor asignado.
model ScheduleSession {
  id           Int      @id @default(autoincrement())
  type         String   // TEORIA | SIMULADOR | VUELO
  date         DateTime // solo el día
  startTime    String   // "HH:MM"
  endTime      String   // "HH:MM"
  studentId    Int
  student      Student  @relation(fields: [studentId], references: [id])
  instructorId Int
  instructor   User     @relation("SesionesComoInstructor", fields: [instructorId], references: [id])
  notes        String?
  createdById  Int
  createdBy    User     @relation("SesionesCreadas", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
}

// Solicitud interna: cualquiera le puede pedir algo a cualquiera. Quien la
// recibe (assignee) es quien la mueve de estado; quien la creó (requester)
// solo hace seguimiento.
model Request {
  id           Int       @id @default(autoincrement())
  title        String
  description  String?   @db.Text
  status       String    @default("PENDIENTE") // PENDIENTE | EN_PROCESO | COMPLETADA | RECHAZADA
  requesterId  Int
  requester    User      @relation("SolicitudesCreadas", fields: [requesterId], references: [id])
  assigneeId   Int
  assignee     User      @relation("SolicitudesRecibidas", fields: [assigneeId], references: [id])
  fileData     String?   @db.Text // archivo adjunto opcional, en base64
  fileName     String?
  mimeType     String?
  responseNote String?   // comentario al resolver/rechazar
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
}
